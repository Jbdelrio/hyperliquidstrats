# ============================================================
# Artemisia v9 — Environment variable configuration
# Copy to .env and fill in your values (never commit .env!)
# ============================================================

# ── LLM Overlay ────────────────────────────────────────────────────────────
LLM_ENABLED=false                   # Set true to activate (disabled by default)
LLM_PROVIDER=openai_compatible      # openai_compatible | dummy
LLM_API_KEY=                        # Your API key (leave empty for dummy mode)
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=20
LLM_ARCHITECTURE=independent_ensemble   # independent_ensemble | sequential_pipeline
LLM_HORIZON_MINUTES=60
LLM_MIN_EDGE_PROB=0.57              # Minimum prob to suggest LONG/SHORT
LLM_MAX_DISAGREEMENT=0.18           # Agent disagreement threshold
LLM_REQUIRE_RISK_APPROVAL=true      # RiskManagerAgent veto blocks trade
LLM_LIVE_MODE_BLOCK_ON_ERROR=false  # Block trade if LLM unavailable in live mode
LLM_LOG_PREDICTIONS=true            # Log to data/llm_predictions.csv
LLM_MAX_OHLCV_ROWS=60               # Max bars sent to LLM
LLM_USE_CROSS_EXCHANGE=true         # Use CrossExchangeAgent when data available
LLM_SAMPLE_RATE=1.0                 # Fraction of decisions evaluated by LLM (1.0=all, 0.5=50%)

# ── Exchange — Global ───────────────────────────────────────────────────────
DEFAULT_EXCHANGE=hyperliquid
ENABLED_EXCHANGES=hyperliquid       # Add: hyperliquid,binance,bitget

GLOBAL_LIVE_TRADING=false           # Master live trading switch — KEEP FALSE until ready

# ── Hyperliquid (primary exchange) ─────────────────────────────────────────
HYPERLIQUID_ENABLED=true
HYPERLIQUID_LIVE_TRADING=false      # Set true AND GLOBAL_LIVE_TRADING=true for live
HYPERLIQUID_WS_URL=wss://api.hyperliquid.xyz/ws
HYPERLIQUID_REST_URL=https://api.hyperliquid.xyz/info

# ── Binance USDT-M Futures (data-only by default) ──────────────────────────
BINANCE_ENABLED=false               # Set true to enable data feed
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true                # Start on testnet
BINANCE_LIVE_TRADING=false          # Requires GLOBAL_LIVE_TRADING=true too

# ── Bitget USDT-M Perpetuals (data-only by default) ────────────────────────
BITGET_ENABLED=false                # Set true to enable data feed
BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_API_PASSPHRASE=
BITGET_TESTNET=true
BITGET_LIVE_TRADING=false           # Requires GLOBAL_LIVE_TRADING=true too

# ── Cross-Exchange Comparison ───────────────────────────────────────────────
CROSS_EXCHANGE_ENABLED=false
CROSS_EXCHANGE_SYMBOLS=BTC,ETH,SOL
CROSS_EXCHANGE_MAX_PRICE_DEVIATION_BPS=15
CROSS_EXCHANGE_MAX_SPREAD_BPS=8
CROSS_EXCHANGE_REQUIRE_CONFIRMATION=false
