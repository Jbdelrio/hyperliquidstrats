{
  "_comment": "ADAPTIVE — $500 per strategy, all strategies whose dependencies are wired. Strategies needing external feeds (spot for SpotPerpBasis, hedge leg for FundingCarryHedged) stay DISABLED with explicit reason. RegimeController + manual execution + per-strategy data_requirements + warmup tracking.",
  "_capital_note": "capital = $500 × (active trading strategies). funding/basis strategies stay disabled until their data feeds are wired — DO NOT enable naïvely or paper PnL won't reflect any real trade.",
  "capital": 6500,
  "paper_mode": true,
  "websocket_url": "wss://api.hyperliquid.xyz/ws",
  "subscription_delay_s": 0.15,

  "seconds_features": {
    "enabled": true,
    "feature_interval_s": 1.0,
    "max_history_seconds": 600,
    "log_enabled": true,
    "log_path": "logs/seconds_features.csv",
    "log_interval_s": 1.0,
    "min_warmup_seconds": 90,
    "stale_book_s": 5.0
  },

  "market_quality_gate": {
    "enabled": true,
    "decision_interval_s": 20,
    "min_seconds_warmup": 90,
    "max_book_age_s": 3.0,
    "max_trade_age_s": 30.0,
    "max_latency_p95_ms": 1500,
    "max_spread_bps_by_symbol": {
      "BTC": 6.0, "ETH": 7.0, "SOL": 10.0, "HYPE": 14.0, "DEFAULT": 18.0
    },
    "min_volume_30s_usd_by_symbol": {
      "BTC": 15000, "ETH": 8000, "SOL": 4000, "HYPE": 1500, "DEFAULT": 1000
    },
    "max_realized_vol_60s_bps": 80,
    "max_toxicity_score": 0.80,
    "min_liquidity_score": 0.25,
    "block_if_queue_drops": true,
    "block_if_crossed_book_seen": true,
    "ofi_block_threshold": 0.35,
    "depth_block_threshold": 0.35
  },

  "decision_throttle": {
    "enabled": true,
    "min_seconds_between_entries_per_symbol": 30,
    "min_seconds_between_entries_per_strategy": 45,
    "max_entries_per_symbol_per_hour": 20,
    "max_entries_global_per_hour": 120
  },

  "regime_controller": {
    "enabled": true,
    "snapshot_interval_s": 30,
    "max_notional_multiplier": 1.0,
    "min_notional_multiplier": 0.25,
    "adjust_only_in_regimes": [
      "LOW_VOL_RANGE", "HIGH_VOL_TREND", "HIGH_VOL_CHAOTIC",
      "BTC_CRASH", "TOXIC_FLOW", "ILLIQUID_WIDE_SPREAD", "NORMAL"
    ]
  },

  "fees": {"maker_bps": 1.5, "taker_bps": 4.5, "assume_rebates": false},

  "paper_simulation": {
    "paper_latency_ms": 150,
    "max_pending_seconds_taker": 10,
    "max_pending_seconds_maker": 30,
    "base_slippage_bps": 2.0,
    "depth_slippage_enabled": true,
    "partial_fills_enabled": true,
    "tp_fill_mode": "market_after_touch",
    "stop_fill_mode": "market_after_touch",
    "maker_queue_model": "conservative"
  },

  "execution_filters": {
    "enabled": true,
    "min_expected_net_profit_usd": 0.50,
    "min_expected_net_profit_pct_of_notional": 0.0006,
    "min_reward_risk_ratio": 1.0,
    "taker_fee_bps": 4.5,
    "slippage_bps": 2.0,
    "min_hold_seconds": 30,
    "cooldown_win_s": 120,
    "cooldown_loss_s": 300
  },

  "strategies": [
    {
      "_comment": "TICK SCALPER — small notional ($50), 1 pos. ~5-10 trades/h.",
