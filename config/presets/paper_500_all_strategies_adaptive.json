  "risk": {
    "_comment": "Per-strategy: max DD 3%/day = $15. Total cap: 6.5k notional × 1 ≈ open exposure ceiling.",
    "max_dd_daily_pct": 0.030,
    "max_dd_total_pct": 0.080,
    "max_open_positions": 18,
    "max_notional_total": 6500,
    "network_timeout_s": 60,
    "max_trades_per_hour": 150,
    "max_loss_streak": 6,
    "btc_move_5m_pct": 2.5,
    "max_pick_rate": 0.80,
    "rampage_suspend_s": 300,
    "streak_suspend_s": 600,
    "volguard_suspend_s": 300
