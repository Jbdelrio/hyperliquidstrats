        "stop_loss_pct": 0.004, "take_profit_pct": 0.005,
        "max_hold_seconds": 120, "cooldown_s": 20,
        "taker_fee_bps": 4.5, "slippage_bps": 2.0, "min_cost_ratio": 1.0
