      "capital_allocated_usd": 500,
      "max_positions": 1,
      "max_position_size_usd": 50,
      "kill_after_consecutive_losses": 4,
      "suspend_minutes_on_kill": 15,
      "coins": ["BTC", "ETH", "SOL", "HYPE"],
      "params": {
        "imbalance_levels": 5, "imbalance_entry_threshold": 0.30,
        "min_persistence_updates": 2, "max_spread_bps": 10.0,
