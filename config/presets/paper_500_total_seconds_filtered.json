{
  "_comment": "★ PAPER 500 IDEAL — $500 PER STRATEGY (not total). Goal: collect seconds-feature data AND test every strategy with it. Tick-based strategies tuned for ~2-3 trades / 2 min; bar strategies trade at their natural cadence. MarketQualityGate filters bad regimes, DecisionThrottle prevents runaway trading. Paper executor uses market-after-touch exits and fees-from-config so PnL is realistic.",
  "_capital_note": "capital = sum of per-strategy budgets (15 trading strats × $500 = $7500 paper notional budget). The kill-switch caps total open exposure separately via risk.max_notional_total.",
  "capital": 7500,
  "paper_mode": true,
  "websocket_url": "wss://api.hyperliquid.xyz/ws",
  "subscription_delay_s": 0.15,

  "seconds_features": {
    "enabled": true,
    "feature_interval_s": 1.0,
    "max_history_seconds": 600,
    "log_enabled": true,
    "log_path": "logs/seconds_features.csv",
    "log_interval_s": 1.0,
    "min_warmup_seconds": 90,
    "stale_book_s": 5.0
  },

  "market_quality_gate": {
    "_comment": "Filters loosened a bit vs the 500-total preset so tick strategies can actually fire 2-3 / 2min during normal regimes. Still hard-blocks crossed/stale books and obvious toxicity.",
    "enabled": true,
    "decision_interval_s": 20,
    "min_seconds_warmup": 90,
    "max_book_age_s": 3.0,
    "max_trade_age_s": 20.0,
    "max_latency_p95_ms": 1500,
    "max_spread_bps_by_symbol": {
      "BTC": 6.0,
      "ETH": 7.0,
      "SOL": 10.0,
      "HYPE": 14.0,
      "DEFAULT": 18.0
    },
    "min_volume_30s_usd_by_symbol": {
      "BTC": 15000,
      "ETH": 8000,
      "SOL": 4000,
      "HYPE": 1500,
      "DEFAULT": 1000
    },
    "max_realized_vol_60s_bps": 80,
    "max_toxicity_score": 0.80,
    "min_liquidity_score": 0.25,
    "block_if_queue_drops": true,
    "block_if_crossed_book_seen": true,
    "ofi_block_threshold": 0.30,
    "depth_block_threshold": 0.30
  },

  "decision_throttle": {
    "_comment": "Targets ~2 trades / min globally (120 / hour). Strategy-level gap 45s lets a fast scalper fire ~80/h on its own; symbol-level gap 30s avoids correlated re-entries.",
    "enabled": true,
    "min_seconds_between_entries_per_symbol": 30,
    "min_seconds_between_entries_per_strategy": 45,
    "max_entries_per_symbol_per_hour": 20,
    "max_entries_global_per_hour": 120
  },

  "fees": {
    "maker_bps": 1.5,
    "taker_bps": 4.5,
    "assume_rebates": false
  },

  "paper_simulation": {
    "paper_latency_ms": 150,
    "max_pending_seconds_taker": 30,
    "max_pending_seconds_maker": 120,
    "base_slippage_bps": 2.0,
    "depth_slippage_enabled": true,
    "partial_fills_enabled": true,
    "tp_fill_mode": "market_after_touch",
    "stop_fill_mode": "market_after_touch",
    "maker_queue_model": "conservative"
  },

  "execution_filters": {
    "enabled": true,
    "min_expected_net_profit_usd": 0.80,
    "min_expected_net_profit_pct_of_notional": 0.0008,
    "min_reward_risk_ratio": 1.0,
    "taker_fee_bps": 4.5,
    "slippage_bps": 2.0,
    "min_hold_seconds": 30,
    "cooldown_win_s": 120,
    "cooldown_loss_s": 300
  },

