{
  "_comment": "Micro-live safe mode — 1-3 USD per trade. READ BEFORE USE. Requires env var ARTEMISIA_ALLOW_MICRO_LIVE=true to start.",
  "mode": "micro_live",
  "capital": 100,
  "paper_mode": false,
  "require_env_arm": "ARTEMISIA_ALLOW_MICRO_LIVE",
  "max_order_notional_usd": 3,
  "max_daily_loss_usd": 5,
  "max_total_loss_usd": 10,
  "max_open_positions": 1,
  "max_trades_per_hour": 5,
  "allow_only_symbols": ["BTC", "ETH", "SOL"],
  "disable_llm_overlay": true,
  "disable_strategies": ["MetaAlpha", "FundingArbitrage", "RotationMomentum", "OBImbalanceScalper"],

  "websocket_url": "wss://api.hyperliquid.xyz/ws",
  "subscription_delay_s": 0.15,

  "paper_simulation": {
    "paper_latency_ms":           150,
    "max_pending_seconds_taker":  30,
    "max_pending_seconds_maker":  120,
    "base_slippage_bps":          2.0
  },

  "portfolio_risk": {
    "max_coin_exposure_pct":   0.35,
    "max_net_exposure_pct":    0.50,
    "max_family_exposure_pct": 0.40,
    "max_correlated_same_dir": 1
  },

  "execution_filters": {
    "enabled": true,
    "min_expected_net_profit_usd": 0.02,
    "min_expected_net_profit_pct_of_notional": 0.004,
    "min_reward_risk_ratio": 1.3,
    "taker_fee_bps": 3.0,
    "slippage_bps": 4.0,
    "min_hold_seconds": 60,
    "cooldown_win_s": 300,
    "cooldown_loss_s": 900
  },

  "strategies": [
    {
      "name": "MomentumLS",
      "class": "MomentumLongShort",
      "enabled": true,
      "capital_allocated_usd": 100,
      "max_positions": 1,
      "max_position_size_usd": 3,
      "kill_after_consecutive_losses": 3,
      "suspend_minutes_on_kill": 60,
      "coins": ["BTC", "ETH", "SOL"],
      "params": {
        "rerank_seconds": 60,
        "top_k_long": 1,
        "bottom_k_short": 1,
        "spread_bps_max": 20.0,
        "r_15m_max_pct": 4.0,
        "stop_loss_pct": 1.0,
        "take_profit_pct": 2.0,
        "trailing_stop_pct": 1.0,
        "max_hold_hours": 12
      }
    },
    {
      "name": "BreakoutControlled",
      "class": "BreakoutControlled",
      "enabled": true,
      "capital_allocated_usd": 100,
      "max_positions": 1,
      "max_position_size_usd": 3,
      "kill_after_consecutive_losses": 3,
      "suspend_minutes_on_kill": 60,
      "coins": ["BTC", "ETH", "SOL"],
      "params": {
        "lookback_bars": 20,
        "bo_max_pct": 4.0,
        "vr_min": 1.5,
        "spread_bps_max": 20.0,
        "take_profit_pct": 2.5,
        "stop_below_resistance_pct": 1.0,
        "max_hold_hours": 8
      }
    },
    {
      "name": "RSIBollingerReversion",
      "class": "RSIBollingerReversionStrategy",
      "enabled": true,
      "capital_allocated_usd": 100,
      "max_positions": 1,
      "max_position_size_usd": 3,
      "kill_after_consecutive_losses": 3,
      "suspend_minutes_on_kill": 60,
      "coins": ["BTC", "ETH", "SOL"],
      "params": {
        "rsi_period": 14,
        "rsi_oversold": 30,
        "zscore_period": 30,
        "zscore_entry": -2.0,
        "bb_period": 20,
        "bb_k": 2.0,
        "ema_1h_period": 100,
        "stop_loss_pct": 0.01,
        "take_profit_pct": 0.02,
        "time_stop_bars": 12,
        "min_cost_ratio": 2.0,
        "cooldown_s": 90
      }
    },
    { "name": "S8EMS",                  "class": "S8EconophysicsMakerScalping",   "enabled": false, "capital_allocated_usd": 0, "max_positions": 0, "max_position_size_usd": 0, "coins": ["BTC","ETH"], "params": {} },
    { "name": "MeanReversionKalman",    "class": "MeanReversionKalman",            "enabled": false, "capital_allocated_usd": 0, "max_positions": 0, "max_position_size_usd": 0, "coins": ["BTC","ETH"], "params": {} },
    { "name": "FundingArbitrage",       "class": "FundingArbitrage",               "enabled": false, "capital_allocated_usd": 0, "max_positions": 0, "max_position_size_usd": 0, "coins": ["BTC","ETH"], "params": {} },
    { "name": "DonchianTrend",          "class": "DonchianTrendStrategy",          "enabled": false, "capital_allocated_usd": 0, "max_positions": 0, "max_position_size_usd": 0, "coins": ["BTC","ETH"], "params": {} },
    { "name": "RotationMomentum",       "class": "RotationMomentumStrategy",       "enabled": false, "capital_allocated_usd": 0, "max_positions": 0, "max_position_size_usd": 0, "coins": ["BTC","ETH"], "params": {} },
    { "name": "RelativeValue",          "class": "RelativeValueStrategy",          "enabled": false, "capital_allocated_usd": 0, "max_positions": 0, "max_position_size_usd": 0, "coins": ["BTC","ETH"], "params": {} },
    { "name": "SpotPerpBasis",          "class": "SpotPerpBasisStrategy",          "enabled": false, "capital_allocated_usd": 0, "max_positions": 0, "max_position_size_usd": 0, "coins": ["BTC","ETH"], "params": {} },
    { "name": "FundingCarryHedged",     "class": "FundingCarryHedgedStrategy",     "enabled": false, "capital_allocated_usd": 0, "max_positions": 0, "max_position_size_usd": 0, "coins": ["BTC","ETH"], "params": {} },
    { "name": "OBImbalanceScalper",     "class": "OrderBookImbalanceScalper",      "enabled": false, "capital_allocated_usd": 0, "max_positions": 0, "max_position_size_usd": 0, "coins": ["BTC","ETH"], "params": {} },
    { "name": "VolatilityRegimeBreakout","class": "VolatilityRegimeBreakoutStrategy","enabled": false,"capital_allocated_usd": 0, "max_positions": 0, "max_position_size_usd": 0, "coins": ["BTC","ETH"], "params": {} },
    { "name": "MetaAlpha",              "class": "MetaAlphaStrategy",              "enabled": false, "capital_allocated_usd": 0, "max_positions": 0, "max_position_size_usd": 0, "coins": ["BTC","ETH"], "params": {} }
  ],

  "risk": {
    "max_dd_daily_pct": 0.05,
    "max_dd_total_pct": 0.10,
    "max_open_positions": 1,
    "max_notional_total": 5,
    "network_timeout_s": 60,
    "max_trades_per_hour": 5,
    "max_loss_streak": 3,
    "btc_move_5m_pct": 3.0,
    "max_pick_rate": 0.85,
    "rampage_suspend_s": 600,
    "streak_suspend_s": 1800,
    "volguard_suspend_s": 600
  },

  "logging": {
    "level": "INFO",
    "file": "logs/engine_v9.log",
    "trade_log": "logs/fills_v9.csv",
    "metrics_log": "metrics_v9/metrics_v9.csv",
    "dashboard_interval_s": 60,
    "decision_log": "logs/decisions_v9.csv",
    "decision_logging_enabled": true,
    "risk_events_log": "logs/risk_events.csv"
  },

  "runtime": {
    "control_file": "runtime/control.json",
    "result_file": "runtime/control_result.json",
    "status_file": "runtime/strategy_status.json",
    "calibration_file": "runtime/calibration_data.json",
    "status_interval_s": 10
  }
}
