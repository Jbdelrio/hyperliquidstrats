{
  "_comment": "Artemisia v9 — S8 EMS. 14-day paper STRICT before live.",

  "capital": 500,
  "paper_mode": true,

  "symbols": ["BTC", "ETH", "SOL", "HYPE", "AVAX", "LINK",
               "ARB", "OP", "AAVE", "LTC", "BCH", "XRP"],

  "websocket_url": "wss://api.hyperliquid.xyz/ws",
  "subscription_delay_s": 0.15,

  "strategy": {
    "base_notional_pct": 0.04,
