{
  "_comment": "Artemisia v9 — multi-strategy. 14-day paper STRICT before live.",

  "capital": 500,
  "paper_mode": true,

  "websocket_url": "wss://api.hyperliquid.xyz/ws",
  "subscription_delay_s": 0.15,

  "strategies": [
    {
      "name": "S8EMS",
      "class": "S8EconophysicsMakerScalping",
      "_comment": "Maker scalping — disabled by default (spread too tight on most coins)",
      "enabled": false,
      "capital_allocated_usd": 100,
      "max_positions": 1,
      "max_position_size_usd": 100,
      "kill_after_consecutive_losses": 5,
      "suspend_minutes_on_kill": 30,
      "coins": ["BTC","ETH","SOL","HYPE","AVAX","LINK","ARB","OP","AAVE","LTC","BCH","XRP"],
      "params": {
        "base_notional_pct": 0.04,
        "max_leverage": 5,
        "min_spread_bps": 4.0,
        "max_spread_bps": 20.0,
        "quote_refresh_s": 5.0,
        "max_hold_s": 60,
        "stop_loss_bps": 30,
        "kalman_process_noise": 1e-7,
        "kalman_obs_noise": 1e-5,
        "bouchaud_decay_s": 30,
        "wavelet_threshold": 3.0,
        "wavelet_cooldown_s": 30
      }
    },
    {
      "name": "MomentumLS",
      "class": "MomentumLongShort",
      "_comment": "Cross-sectional momentum — long top-K, short bottom-K every 5min",
      "enabled": true,
      "capital_allocated_usd": 150,
      "max_positions": 4,
      "max_position_size_usd": 75,
      "kill_after_consecutive_losses": 5,
      "suspend_minutes_on_kill": 30,
      "coins": ["BTC","ETH","SOL","HYPE","AVAX","LINK","ARB","OP","AAVE","LTC","BCH","XRP"],
      "params": {
        "rerank_seconds": 300,
        "top_k_long": 4,
        "bottom_k_short": 4,
        "score_threshold": 75,
        "spread_bps_max": 15.0,
        "r_15m_max_pct": 4.0,
        "stop_loss_pct": 2.5,
        "take_profit_pct": 3.0,
        "trailing_stop_pct": 1.5,
        "max_hold_hours": 4
      }
    },
    {
      "name": "BreakoutControlled",
      "class": "BreakoutControlled",
      "_comment": "N-bar resistance breakout with volume ratio confirmation",
      "enabled": true,
      "capital_allocated_usd": 100,
      "max_positions": 2,
      "max_position_size_usd": 75,
      "kill_after_consecutive_losses": 4,
      "suspend_minutes_on_kill": 60,
      "coins": ["BTC","ETH","SOL","HYPE","AVAX","LINK","ARB","OP","AAVE","LTC","BCH","XRP"],
      "params": {
        "lookback_bars": 60,
        "bo_max_pct": 4.0,
        "vr_min": 1.5,
        "spread_bps_max": 15.0,
        "take_profit_pct": 5.0,
        "stop_below_resistance_pct": 0.5,
        "max_hold_hours": 2
      }
    },
    {
      "name": "MeanReversionKalman",
      "class": "MeanReversionKalman",
      "_comment": "Kalman z-score mean reversion — BTC/ETH/SOL only (most liquid)",
      "enabled": false,
      "capital_allocated_usd": 100,
      "max_positions": 1,
      "max_position_size_usd": 100,
      "kill_after_consecutive_losses": 5,
      "suspend_minutes_on_kill": 30,
      "coins": ["BTC","ETH","SOL"],
      "params": {
        "warmup_seconds": 300,
        "z_entry": 2.0,
        "z_exit": 0.0,
        "z_stop": 3.5,
        "spread_bps_max": 5.0,
        "vol_max_pct_per_min": 0.15,
        "max_hold_minutes": 30,
        "kalman_process_noise": 1e-6,
        "kalman_obs_noise": 1e-4
      }
    },
    {
      "name": "FundingArbitrage",
      "class": "FundingArbitrage",
      "_comment": "Short perp when funding > threshold — disabled until >260% APR consistently",
      "enabled": false,
      "capital_allocated_usd": 50,
      "max_positions": 2,
      "max_position_size_usd": 50,
      "kill_after_consecutive_losses": 3,
      "suspend_minutes_on_kill": 120,
      "coins": ["BTC","ETH","SOL","HYPE","AVAX"],
      "params": {
        "funding_entry_threshold_pct_per_hour": 0.03,
        "funding_exit_threshold_pct_per_hour": 0.005,
        "r_24h_min_pct": 5.0,
        "stop_loss_pct": 3.0,
        "max_hold_cycles": 3
      }
    }
  ],

  "risk": {
    "max_dd_daily_pct": 0.030,
    "max_dd_total_pct": 0.060,
    "max_open_positions": 8,
    "max_notional_total": 2000,
    "network_timeout_s": 60,
    "max_trades_per_hour": 50,
    "max_loss_streak": 6,
    "btc_move_5m_pct": 1.2,
    "max_pick_rate": 0.65,
    "rampage_suspend_s": 600,
    "streak_suspend_s": 1800,
    "volguard_suspend_s": 900
  },

  "logging": {
    "level": "INFO",
    "file": "logs/engine_v9.log",
    "trade_log": "logs/fills_v9.csv",
    "metrics_log": "metrics_v9/metrics_v9.csv",
    "dashboard_interval_s": 60,
    "decision_log": "logs/decisions_v9.csv",
    "decision_logging_enabled": true
  },

  "runtime": {
    "control_file": "runtime/control.json",
    "result_file": "runtime/control_result.json",
    "status_file": "runtime/strategy_status.json",
    "calibration_file": "runtime/calibration_data.json",
    "status_interval_s": 10
  }
}
