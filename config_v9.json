{
  "_comment": "Artemisia v9 — multi-strategy. 14-day paper STRICT before live.",

  "capital": 500,
  "paper_mode": true,

  "websocket_url": "wss://api.hyperliquid.xyz/ws",
  "subscription_delay_s": 0.15,

  "strategies": [
    {
      "name": "S8EMS",
      "class": "S8EconophysicsMakerScalping",
      "_comment": "Maker scalping — lowered spread floor, faster quotes, longer hold",
      "enabled": true,
      "capital_allocated_usd": 100,
      "max_positions": 2,
      "max_position_size_usd": 60,
      "kill_after_consecutive_losses": 8,
      "suspend_minutes_on_kill": 10,
      "coins": ["BTC","ETH","SOL","HYPE","AVAX","LINK","ARB","OP","AAVE","LTC","BCH","XRP"],
      "params": {
        "base_notional_pct": 0.04,
        "max_leverage": 5,
        "min_spread_bps": 1.5,
        "max_spread_bps": 30.0,
        "quote_refresh_s": 2.0,
        "max_hold_s": 180,
        "stop_loss_bps": 50,
        "kalman_process_noise": 1e-7,
        "kalman_obs_noise": 1e-5,
        "bouchaud_decay_s": 15,
        "wavelet_threshold": 6.0,
        "wavelet_cooldown_s": 10
      }
    },
    {
      "name": "MomentumLS",
      "class": "MomentumLongShort",
      "_comment": "Reranks every 60s, low score threshold, more candidates, longer hold",
      "enabled": true,
      "capital_allocated_usd": 150,
      "max_positions": 6,
      "max_position_size_usd": 50,
      "kill_after_consecutive_losses": 8,
      "suspend_minutes_on_kill": 10,
      "coins": ["BTC","ETH","SOL","HYPE","AVAX","LINK","ARB","OP","AAVE","LTC","BCH","XRP"],
      "params": {
        "rerank_seconds": 60,
        "top_k_long": 6,
        "bottom_k_short": 6,
        "score_threshold": 20,
        "spread_bps_max": 30.0,
        "r_15m_max_pct": 8.0,
        "stop_loss_pct": 4.0,
        "take_profit_pct": 1.5,
        "trailing_stop_pct": 2.0,
        "max_hold_hours": 12
      }
    },
    {
      "name": "BreakoutControlled",
      "class": "BreakoutControlled",
      "_comment": "Shorter lookback, lower VR, wider stops, much longer hold",
      "enabled": true,
      "capital_allocated_usd": 100,
      "max_positions": 3,
      "max_position_size_usd": 60,
      "kill_after_consecutive_losses": 6,
      "suspend_minutes_on_kill": 10,
      "coins": ["BTC","ETH","SOL","HYPE","AVAX","LINK","ARB","OP","AAVE","LTC","BCH","XRP"],
      "params": {
        "lookback_bars": 15,
        "bo_max_pct": 10.0,
        "vr_min": 1.0,
        "spread_bps_max": 30.0,
        "take_profit_pct": 2.5,
        "stop_below_resistance_pct": 1.5,
        "max_hold_hours": 8
      }
    },
    {
      "name": "MeanReversionKalman",
      "class": "MeanReversionKalman",
      "_comment": "Lower z_entry=1.0 = more signals, faster warmup, longer hold",
      "enabled": true,
      "capital_allocated_usd": 100,
      "max_positions": 2,
      "max_position_size_usd": 60,
      "kill_after_consecutive_losses": 8,
      "suspend_minutes_on_kill": 10,
      "coins": ["BTC","ETH","SOL"],
      "params": {
        "warmup_seconds": 60,
        "z_entry": 1.0,
        "z_exit": 0.2,
        "z_stop": 4.5,
        "spread_bps_max": 10.0,
        "vol_max_pct_per_min": 1.0,
        "max_hold_minutes": 120,
        "kalman_process_noise": 1e-6,
        "kalman_obs_noise": 1e-4
      }
    },
    {
      "name": "FundingArbitrage",
      "class": "FundingArbitrage",
      "_comment": "Lower entry threshold = trade whenever funding is elevated",
      "enabled": true,
      "capital_allocated_usd": 50,
      "max_positions": 3,
      "max_position_size_usd": 30,
      "kill_after_consecutive_losses": 6,
      "suspend_minutes_on_kill": 10,
      "coins": ["BTC","ETH","SOL","HYPE","AVAX"],
      "params": {
        "funding_entry_threshold_pct_per_hour": 0.005,
        "funding_exit_threshold_pct_per_hour": 0.001,
        "r_24h_min_pct": 0.5,
        "stop_loss_pct": 5.0,
        "max_hold_cycles": 12
      }
    }
  ],

  "risk": {
    "max_dd_daily_pct": 0.050,
    "max_dd_total_pct": 0.100,
    "max_open_positions": 16,
    "max_notional_total": 5000,
    "network_timeout_s": 60,
    "max_trades_per_hour": 200,
    "max_loss_streak": 10,
    "btc_move_5m_pct": 3.0,
    "max_pick_rate": 0.85,
    "rampage_suspend_s": 120,
    "streak_suspend_s": 300,
    "volguard_suspend_s": 120
  },

  "logging": {
    "level": "INFO",
    "file": "logs/engine_v9.log",
    "trade_log": "logs/fills_v9.csv",
    "metrics_log": "metrics_v9/metrics_v9.csv",
    "dashboard_interval_s": 60,
    "decision_log": "logs/decisions_v9.csv",
    "decision_logging_enabled": true
  },

  "runtime": {
    "control_file": "runtime/control.json",
    "result_file": "runtime/control_result.json",
    "status_file": "runtime/strategy_status.json",
    "calibration_file": "runtime/calibration_data.json",
    "status_interval_s": 10
  }
}
